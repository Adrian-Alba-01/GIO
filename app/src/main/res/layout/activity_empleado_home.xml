<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <!-- ===== BARRA DE NAVEGACIÓN INFERIOR (4 iconos) ===== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#013276"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <!-- Inicio (activo, blanco) -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_today"
                android:tint="#FFFFFF"
                android:contentDescription="Inicio"/>
        </LinearLayout>

        <!-- Ubicación/Obras -->
        <LinearLayout
            android:id="@+id/navUbicacion"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#9AB4E8"
                android:contentDescription="Ubicación"/>
        </LinearLayout>

        <!-- Tareas -->
        <LinearLayout
            android:id="@+id/navTareas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#9AB4E8"
                android:contentDescription="Tareas"/>
        </LinearLayout>

        <!-- Perfil -->
        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="#9AB4E8"
                android:contentDescription="Perfil"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#013276"
                android:paddingHorizontal="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="20dp"
                android:orientation="vertical">

                <!-- Fila: Bienvenido + Campana -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvBienvenido"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="¡Bienvenido Adrian!"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:id="@+id/ivNotificaciones"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:tint="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Notificaciones"/>
                </LinearLayout>

                <!-- Fila: Tarjeta timer + botones laterales -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Tarjeta oscura: reloj + dirección + estado -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_blue_dark"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginEnd="10dp">

                        <!-- Fila: Reloj + punto estado -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:id="@+id/tvReloj"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="00:00:00 H"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:textStyle="bold"/>

                            <!-- Punto de estado (verde/amarillo según fichaje) -->
                            <TextView
                                android:id="@+id/tvEstadoFichaje"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● Inactivo"
                                android:textColor="#FFC107"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Dirección de la obra -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvDireccion"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cargando obra..."
                                android:textColor="#CCDDFF"
                                android:textSize="13sp"/>

                            <ImageView
                                android:id="@+id/ivUbicacion"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_mylocation"
                                android:tint="#CCDDFF"
                                android:contentDescription="Ubicación"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Botones a la derecha: Parar + Fotos -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Botón parar (btnFichar actúa como fichar/desfichar,
                             este es solo el icono visual de parar) -->
                        <ImageView
                            android:id="@+id/ivFotos"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_media_pause"
                            android:tint="#013276"
                            android:background="@drawable/bg_btn_square"
                            android:padding="10dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Parar"/>

                        <!-- Botón fotos/cambiar -->
                        <ImageView
                            android:id="@+id/ivPerfil"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="#013276"
                            android:background="@drawable/bg_btn_square"
                            android:padding="10dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Fotos"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== CUERPO ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <!-- Botón Horas mensuales -->
                <Button
                    android:id="@+id/btnHorasMensuales"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Horas mensuales"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2255CC"
                    android:layout_marginBottom="16dp"/>

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCCCCC"
                    android:layout_marginBottom="14dp"/>

                <!-- Título Tarea Actual + icono -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tarea Actual"
                        android:textColor="#013276"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:tint="#013276"
                        android:contentDescription="Tarea actual"/>
                </LinearLayout>

                <!-- RecyclerView Tarea Actual -->
                <!-- nestedScrollingEnabled="false" para que funcione dentro del ScrollView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTareaActual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="16dp"/>

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCCCCC"
                    android:layout_marginBottom="14dp"/>

                <!-- Título Tareas Pendientes + icono -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tareas Pendientes"
                        android:textColor="#013276"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:tint="#013276"
                        android:contentDescription="Tareas pendientes"/>
                </LinearLayout>

                <!-- RecyclerView Tareas Pendientes -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTareasPendientes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="16dp"/>

                <!-- Botón Ver todas -->
                <Button
                    android:id="@+id/btnVerTodas"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Ver todas"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2255CC"
                    android:layout_gravity="center_horizontal"
                    android:paddingHorizontal="32dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Botón Fichar (oculto visualmente en el diseño,
                     pero necesario para el Java — se activa desde tvEstadoFichaje area) -->
                <Button
                    android:id="@+id/btnFichar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Registrar Entrada"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#013276"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>

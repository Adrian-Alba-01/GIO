<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <!-- ===== BOTTOM NAV ===== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#013276"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_today"
                android:tint="#9AB4E8"
                android:contentDescription="Inicio"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navUbicacion"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#9AB4E8"
                android:contentDescription="Ubicación"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTareas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#9AB4E8"
                android:contentDescription="Tareas"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="#9AB4E8"
                android:contentDescription="Perfil"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ===== CONTENIDO ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#013276"
                android:paddingHorizontal="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="24dp"
                android:orientation="vertical">

                <!-- Fila: Atrás + Título -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@android:color/transparent"
                        android:src="@android:drawable/ic_media_previous"
                        android:tint="#FFFFFF"
                        android:contentDescription="Volver"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Horas Mensuales"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Tarjeta resumen total horas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_blue_dark"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total este mes"
                        android:textColor="#AABBDD"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvTotalHoras"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-- h"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"/>

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            android:tint="#CCDDFF"
                            android:contentDescription="Horas"/>
                    </LinearLayout>

                    <!-- Barra de progreso hacia objetivo mensual -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Objetivo: 160 h"
                        android:textColor="#AABBDD"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="6dp"/>

                    <ProgressBar
                        android:id="@+id/progressBarMes"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="160"
                        android:progress="0"
                        android:progressTint="#4CAF50"
                        android:progressBackgroundTint="#1A3A6E"/>

                </LinearLayout>
            </LinearLayout>

            <!-- ===== CUERPO ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCCCCC"
                    android:layout_marginBottom="14dp"/>

                <!-- Selector de mes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageButton
                        android:id="@+id/btnMesAnterior"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_btn_square"
                        android:src="@android:drawable/ic_media_previous"
                        android:tint="#013276"
                        android:contentDescription="Mes anterior"/>

                    <TextView
                        android:id="@+id/tvMesActual"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mayo 2026"
                        android:textColor="#013276"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <ImageButton
                        android:id="@+id/btnMesSiguiente"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_btn_square"
                        android:src="@android:drawable/ic_media_next"
                        android:tint="#013276"
                        android:contentDescription="Mes siguiente"/>
                </LinearLayout>

                <!-- Tarjetas de resumen (días trabajados / media diaria) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- Días trabajados -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_blue_dark"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Días trabajados"
                            android:textColor="#AABBDD"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvDiasTrabajados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Media diaria -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_blue_dark"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Media diaria"
                            android:textColor="#AABBDD"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvMediaDiaria"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- h"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Título detalle por día -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Detalle por día"
                        android:textColor="#013276"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        android:tint="#013276"
                        android:contentDescription="Detalle"/>
                </LinearLayout>

                <!-- ProgressBar de carga -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <!-- RecyclerView con los fichajes del mes -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFichajes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="24dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
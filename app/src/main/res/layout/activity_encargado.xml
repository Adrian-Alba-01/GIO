<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <!-- ===== BARRA DE NAVEGACIÓN INFERIOR ===== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#013276"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_today"
                android:tint="#FFFFFF"
                android:contentDescription="Inicio"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navObras"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_mapmode"
                android:tint="#9AB4E8"
                android:contentDescription="Obras"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPersonal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#9AB4E8"
                android:contentDescription="Personal"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navDocumentos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#9AB4E8"
                android:contentDescription="Documentos"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="#9AB4E8"
                android:contentDescription="Perfil"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#013276"
                android:paddingHorizontal="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="20dp"
                android:orientation="vertical">

                <!-- Fila: Bienvenido + Campana -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvBienvenido"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="¡Bienvenido Adrian!"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:id="@+id/ivCampana"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:tint="#FFFFFF"
                        android:contentDescription="Notificaciones"/>
                </LinearLayout>

                <!-- Tarjeta timer + ubicación -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_blue_dark"
                    android:padding="14dp"
                    android:orientation="vertical">

                    <!-- Fila: Timer + punto estado + botones -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/tvTimer"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="02:23:45 H"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"/>

                        <!-- Punto verde de estado -->
                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/circle_green"
                            android:layout_marginEnd="12dp"/>

                        <!-- Botón parar -->
                        <ImageView
                            android:id="@+id/btnParar"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@android:drawable/ic_media_pause"
                            android:tint="#FFFFFF"
                            android:background="@drawable/bg_btn_round"
                            android:padding="6dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Parar"/>

                        <!-- Botón cambiar obra -->
                        <ImageView
                            android:id="@+id/btnCambiarObra"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@android:drawable/ic_menu_rotate"
                            android:tint="#FFFFFF"
                            android:background="@drawable/bg_btn_round"
                            android:padding="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Cambiar obra"/>
                    </LinearLayout>

                    <!-- Fila: Ubicación -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvUbicacion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Av. Martinez\nCampos, 17, 28040"
                            android:textColor="#CCDDFF"
                            android:textSize="13sp"/>

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            android:tint="#CCDDFF"
                            android:contentDescription="Ubicación"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- CUERPO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <!-- Botón Horas mensuales -->
                <Button
                    android:id="@+id/btnHorasMensuales"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Horas mensuales"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#013276"
                    android:layout_marginBottom="20dp"/>

                <!-- Título Estado del equipo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Estado del equipo"
                        android:textColor="#013276"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_manage"
                        android:tint="#013276"
                        android:contentDescription="Equipo"/>
                </LinearLayout>

                <!-- Tarjeta Estado del equipo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_blue_dark"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <!-- Pedro - Activo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/circle_green"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pedro - Activo"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- María - Descansando -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/circle_yellow"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="María - Descansando"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Juan - Ausente -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/circle_red"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Juan - Ausente"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Botón Ver todos -->
                <Button
                    android:id="@+id/btnVerTodos"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Ver todos"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#013276"
                    android:layout_marginBottom="20dp"/>

                <!-- Título Más apartados -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mas apartados"
                        android:textColor="#013276"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_slideshow"
                        android:tint="#013276"
                        android:contentDescription="Ver todos los apartados"/>
                </LinearLayout>

                <!-- 3 BOTONES: Tareas / Tareas equipo / Incidencias -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="20dp">

                    <!-- Tareas -->
                    <LinearLayout
                        android:id="@+id/btnTareas"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_blue_dark"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:tint="#FFFFFF"
                            android:contentDescription="Tareas"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tareas"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:lines="2"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Tareas equipo -->
                    <LinearLayout
                        android:id="@+id/btnTareasEquipo"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_blue_dark"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_manage"
                            android:tint="#FFFFFF"
                            android:contentDescription="Tareas equipo"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tareas\nequipo"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:lines="2"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Incidencias -->
                    <LinearLayout
                        android:id="@+id/btnIncidencias"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_blue_dark"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:tint="#FFFFFF"
                            android:contentDescription="Incidencias"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Incidencias"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:lines="2"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- BOTÓN CALENDARIO -->
                <Button
                    android:id="@+id/btnCalendario"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Calendario"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#013276"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#0D1F5C">

    <!-- Contenedor principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="0dp">

        <!-- Barra lateral de estado (coloreada por estado) -->
        <View
            android:id="@+id/viewIndicadorTarea"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="#4CAF50" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Badge de estado -->
            <TextView
                android:id="@+id/tvEstadoTarea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="pendiente"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_badge_estado"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="8dp" />

            <!-- Nombre de la tarea -->
            <TextView
                android:id="@+id/tvNombreTarea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre tarea"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="4dp" />

            <!-- Descripción -->
            <TextView
                android:id="@+id/tvDescripcionTarea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción de la tarea"
                android:textColor="#8AADFF"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:visibility="gone" />

            <!-- Fechas con icono -->
            <LinearLayout
                android:id="@+id/llFechas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    android:tint="#5580CC"
                    android:layout_marginEnd="5dp"
                    android:contentDescription="Fechas" />

                <TextView
                    android:id="@+id/tvFechasTarea"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01/06 → 15/06"
                    android:textColor="#5580CC"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Botón completar (columna derecha centrada) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="14dp">

            <TextView
                android:id="@+id/btnCompletarTarea"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="✓"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_check"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
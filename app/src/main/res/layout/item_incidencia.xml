<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A2A6C"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDescripcionIncidencia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Descripción de la incidencia"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEstadoIncidencia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendiente"
            android:textColor="#F44336"
            android:textSize="12sp"
            android:layout_gravity="center_vertical" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvUsuarioIncidencia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reportado por: "
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvFechaIncidencia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2026-01-01"
        android:textColor="#AAAAAA"
        android:textSize="11sp"
        android:layout_marginTop="2dp" />

</LinearLayout>